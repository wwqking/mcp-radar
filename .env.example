# 站点域名（sitemap / canonical / robots / schema / feed 都用它）。默认 https://mcpradars.com
# 预览环境用不同域名时在此覆盖。
NEXT_PUBLIC_SITE_URL=https://mcpradars.com

# 数据源：mock（默认，写死演示数据）| live（本项目采集器拉真实数据）
NEXT_PUBLIC_DATA_SOURCE=mock

# live 模式采集参数 ---------------------------------------------------------

# 采集多少个 server（"先采少量"，控制 GitHub 调用量）。默认 40。
MCP_COLLECT_LIMIT=40

# GitHub token：可选但强烈建议。未认证 60 次/小时，token 5000 次/小时。
# 生成：https://github.com/settings/tokens （只需 public_repo 读权限即可）
GITHUB_TOKEN=

# 采集缓存有效期（毫秒），默认 12 小时。调试时可设短。
# MCP_CACHE_TTL_MS=43200000
