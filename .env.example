# 站点域名（sitemap / canonical / robots / schema / feed 都用它）。默认 https://www.mcpradars.com
# 注意：与 Vercel 实际规范域名一致（apex 已重定向到 www）。预览环境用不同域名时在此覆盖。
NEXT_PUBLIC_SITE_URL=https://www.mcpradars.com

# 数据源：mock（默认，写死演示数据）| live（本项目采集器拉真实数据）
NEXT_PUBLIC_DATA_SOURCE=mock

# live 模式采集参数 ---------------------------------------------------------

# 采集多少个 server（白名单优先 + registry 补量，按 stars 取 top N）。默认 100。
MCP_COLLECT_LIMIT=100

# GitHub token：可选但强烈建议。未认证 60 次/小时，token 5000 次/小时。
# 生成：https://github.com/settings/tokens （只需 public_repo 读权限即可）
GITHUB_TOKEN=

# 采集缓存有效期（毫秒），默认 12 小时。调试时可设短。
# MCP_CACHE_TTL_MS=43200000
